diff --git a/board/rockchip/common/wifi/etc/init.d/S37wifi_auto b/board/rockchip/common/wifi/etc/init.d/S37wifi_auto
new file mode 100755
index 00000000..2d3492ae
--- /dev/null
+++ b/board/rockchip/common/wifi/etc/init.d/S37wifi_auto
@@ -0,0 +1,213 @@
+#!/bin/sh
+
+IFACE="${WIFI_IFACE:-wlan0}"
+CONF="/etc/wpa_supplicant.conf"
+CTRL="/var/run/wpa_supplicant"
+LOG="/tmp/wifi_auto.log"
+STATUS="/tmp/wifi_status"
+PIDFILE="/var/run/wifi_auto_worker.pid"
+
+msg()
+{
+    echo "[wifi_auto] $*" >> "$LOG"
+    echo "[wifi_auto] $*" > /dev/console
+}
+
+set_status()
+{
+    echo "$*" > "$STATUS"
+    msg "$*"
+}
+
+get_ip()
+{
+    ip addr show "$IFACE" 2>/dev/null | awk '/inet /{print $2; exit}'
+}
+
+start_worker()
+{
+    # 防止重复启动多个后台连接任务
+    if [ -f "$PIDFILE" ]; then
+        OLD_PID="$(cat "$PIDFILE" 2>/dev/null)"
+        if [ -n "$OLD_PID" ] && kill -0 "$OLD_PID" 2>/dev/null; then
+            msg "WiFi worker already running, pid=$OLD_PID"
+            exit 0
+        fi
+    fi
+
+    "$0" worker >/dev/null 2>&1 &
+    echo $! > "$PIDFILE"
+
+    msg "WiFi auto connect started in background, pid=$(cat "$PIDFILE")"
+    exit 0
+}
+
+worker()
+{
+    msg "Worker started."
+
+    # 等待 wlan0 出现，但只在后台等，不阻塞开机
+    i=0
+    while [ $i -lt 10 ]; do
+        if [ -e "/sys/class/net/$IFACE" ]; then
+            break
+        fi
+        sleep 1
+        i=$((i + 1))
+    done
+
+    if [ ! -e "/sys/class/net/$IFACE" ]; then
+        set_status "FAILED: $IFACE not found. WiFi driver may not be loaded. Check: ifconfig -a"
+        rm -f "$PIDFILE"
+        exit 0
+    fi
+
+    if [ ! -s "$CONF" ]; then
+        set_status "NO_CONFIG: $CONF not found or empty. Run: wifi_setup \"SSID\" \"PASSWORD\""
+        rm -f "$PIDFILE"
+        exit 0
+    fi
+
+    mkdir -p "$CTRL"
+
+    ifconfig "$IFACE" up 2>/dev/null
+
+    killall wpa_supplicant 2>/dev/null
+
+    msg "Starting wpa_supplicant with $CONF ..."
+    wpa_supplicant -B -Dnl80211,wext -i "$IFACE" -c "$CONF"
+
+    if [ $? -ne 0 ]; then
+        set_status "FAILED: wpa_supplicant start failed. Check $CONF and driver."
+        rm -f "$PIDFILE"
+        exit 0
+    fi
+
+    # 等待关联完成，后台等待，不阻塞系统启动
+    i=0
+    while [ $i -lt 20 ]; do
+        STATE="$(wpa_cli -p "$CTRL" -i "$IFACE" status 2>/dev/null | awk -F= '/^wpa_state=/{print $2}')"
+
+        if [ "$STATE" = "COMPLETED" ]; then
+            msg "WiFi connected to AP. Getting IP..."
+
+            # 优先兼容当前系统里的 dhcpcd；没有 dhcpcd 再用 udhcpc
+            if command -v dhcpcd >/dev/null 2>&1; then
+                msg "Running dhcpcd for $IFACE ..."
+
+                # 停掉旧的 wlan0 dhcpcd，避免旧租约/旧进程干扰
+                dhcpcd -k "$IFACE" 2>/dev/null
+                sleep 1
+
+                # 这里虽然 dhcpcd 会等待，但它运行在后台 worker 里，不会阻塞系统启动
+                dhcpcd -4 -t 30 "$IFACE" >> "$LOG" 2>&1
+
+            elif command -v udhcpc >/dev/null 2>&1; then
+                msg "Running udhcpc for $IFACE ..."
+                udhcpc -n -q -t 5 -T 3 -i "$IFACE" >> "$LOG" 2>&1
+            else
+                set_status "FAILED: No DHCP client found. Need dhcpcd or udhcpc."
+                rm -f "$PIDFILE"
+                exit 0
+            fi
+
+            # DHCP 后再等一会儿，避免 dhcpcd 还在 ARP probing / 写地址
+            j=0
+            IPADDR=""
+            while [ $j -lt 30 ]; do
+                IPADDR="$(get_ip)"
+
+                case "$IPADDR" in
+                    ""|169.254.*)
+                        sleep 1
+                        j=$((j + 1))
+                        ;;
+                    *)
+                        break
+                        ;;
+                esac
+            done
+
+            case "$IPADDR" in
+                ""|169.254.*)
+                    set_status "DHCP_FAILED: WiFi associated, but no valid IP. Current IP: ${IPADDR:-none}"
+                    ;;
+                *)
+                    set_status "OK: WiFi connected. IP: $IPADDR"
+                    ;;
+            esac
+
+            rm -f "$PIDFILE"
+            exit 0
+        fi
+
+        sleep 1
+        i=$((i + 1))
+    done
+
+    set_status "FAILED: WiFi connect timeout. Check SSID/password/router. Run: wifi_setup \"SSID\" \"PASSWORD\""
+    rm -f "$PIDFILE"
+    exit 0
+}
+
+stop_wifi()
+{
+    msg "Stopping WiFi..."
+
+    if [ -f "$PIDFILE" ]; then
+        PID="$(cat "$PIDFILE" 2>/dev/null)"
+        [ -n "$PID" ] && kill "$PID" 2>/dev/null
+        rm -f "$PIDFILE"
+    fi
+
+    dhcpcd -k "$IFACE" 2>/dev/null
+    killall udhcpc 2>/dev/null
+    killall wpa_supplicant 2>/dev/null
+    ifconfig "$IFACE" down 2>/dev/null
+
+    set_status "STOPPED: WiFi stopped."
+}
+
+show_status()
+{
+    echo "===== WiFi auto status ====="
+    cat "$STATUS" 2>/dev/null || echo "No status yet."
+
+    echo
+    echo "===== wlan IP ====="
+    ip addr show "$IFACE" 2>/dev/null || ifconfig "$IFACE" 2>/dev/null
+
+    echo
+    echo "===== wpa_supplicant state ====="
+    wpa_cli -p "$CTRL" -i "$IFACE" status 2>/dev/null || true
+
+    echo
+    echo "===== log tail ====="
+    tail -n 30 "$LOG" 2>/dev/null || true
+}
+
+case "$1" in
+    start)
+        start_worker
+        ;;
+    worker)
+        worker
+        ;;
+    stop)
+        stop_wifi
+        ;;
+    restart)
+        stop_wifi
+        sleep 1
+        start_worker
+        ;;
+    status)
+        show_status
+        ;;
+    *)
+        echo "Usage: $0 {start|stop|restart|status}"
+        exit 1
+        ;;
+esac
+
+exit 0
diff --git a/board/rockchip/common/wifi/etc/profile.d/wifi_notice.sh b/board/rockchip/common/wifi/etc/profile.d/wifi_notice.sh
new file mode 100755
index 00000000..021b752a
--- /dev/null
+++ b/board/rockchip/common/wifi/etc/profile.d/wifi_notice.sh
@@ -0,0 +1,17 @@
+#!/bin/sh
+
+if [ -f /tmp/wifi_status ]; then
+    STATUS="$(cat /tmp/wifi_status 2>/dev/null)"
+
+    case "$STATUS" in
+        OK:*)
+            echo "[WiFi] $STATUS"
+            ;;
+        FAILED:*|NO_CONFIG:*|DHCP_FAILED:*)
+            echo
+            echo "[WiFi WARNING] $STATUS"
+            echo "[WiFi] Run 'wifi_status' for details."
+            echo
+            ;;
+    esac
+fi
