diff --git a/board/rockchip/common/wifi/usr/bin/wifi_setup b/board/rockchip/common/wifi/usr/bin/wifi_setup
new file mode 100755
index 00000000..837493d3
--- /dev/null
+++ b/board/rockchip/common/wifi/usr/bin/wifi_setup
@@ -0,0 +1,53 @@
+#!/bin/sh
+
+IFACE="${WIFI_IFACE:-wlan0}"
+CONF="/etc/wpa_supplicant.conf"
+
+if [ $# -lt 2 ]; then
+    echo "Usage: wifi_setup \"SSID\" \"PASSWORD\""
+    echo "Example: wifi_setup \"PDCN\" \"1234567890\""
+    exit 1
+fi
+
+SSID="$1"
+PASS="$2"
+
+echo "Creating WiFi config for SSID: $SSID"
+
+if command -v wpa_passphrase >/dev/null 2>&1; then
+    {
+        echo "ctrl_interface=/var/run/wpa_supplicant"
+        echo "update_config=1"
+        echo "country=CN"
+        echo
+        wpa_passphrase "$SSID" "$PASS" | sed '/#psk=/d'
+    } > "$CONF"
+else
+    cat > "$CONF" <<EOC
+ctrl_interface=/var/run/wpa_supplicant
+update_config=1
+country=CN
+
+network={
+    ssid="$SSID"
+    psk="$PASS"
+    key_mgmt=WPA-PSK
+}
+EOC
+fi
+
+chmod 600 "$CONF"
+
+echo "WiFi config saved to $CONF"
+echo "Restarting WiFi..."
+
+if [ -x /etc/init.d/S45wifi_auto ]; then
+    /etc/init.d/S45wifi_auto restart
+else
+    ifconfig "$IFACE" up
+    killall wpa_supplicant 2>/dev/null
+    killall udhcpc 2>/dev/null
+    wpa_supplicant -B -Dnl80211,wext -i "$IFACE" -c "$CONF"
+    sleep 5
+    udhcpc -i "$IFACE"
+fi
diff --git a/board/rockchip/common/wifi/usr/bin/wifi_status b/board/rockchip/common/wifi/usr/bin/wifi_status
new file mode 100755
index 00000000..427d6e28
--- /dev/null
+++ b/board/rockchip/common/wifi/usr/bin/wifi_status
@@ -0,0 +1,25 @@
+#!/bin/sh
+
+IFACE="${WIFI_IFACE:-wlan0}"
+STATUS="/tmp/wifi_status"
+LOG="/tmp/wifi_auto.log"
+CTRL="/var/run/wpa_supplicant"
+
+echo "===== WiFi status ====="
+cat "$STATUS" 2>/dev/null || echo "No WiFi status yet."
+
+echo
+echo "===== IP address ====="
+ip addr show "$IFACE" 2>/dev/null || ifconfig "$IFACE" 2>/dev/null
+
+echo
+echo "===== route ====="
+ip route 2>/dev/null || route -n 2>/dev/null
+
+echo
+echo "===== wpa_supplicant ====="
+wpa_cli -p "$CTRL" -i "$IFACE" status 2>/dev/null || echo "wpa_cli unavailable or wpa_supplicant not ready."
+
+echo
+echo "===== recent log ====="
+tail -n 40 "$LOG" 2>/dev/null || echo "No log yet."
